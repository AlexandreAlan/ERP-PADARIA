# =============================================================================
# ERP Padaria - Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# --- Application ---
APP_NAME="ERP Padaria"
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_padaria
DB_USER=padaria_user
DB_PASSWORD=SuaSenhaAqui
# Formato completo (gerado automaticamente a partir dos campos acima):
# DATABASE_URL=mysql+aiomysql://padaria_user:SuaSenhaAqui@localhost:3306/erp_padaria

# --- JWT ---
JWT_SECRET_KEY=troque-por-uma-chave-secreta-forte-aqui-minimo-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas (turno de trabalho)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Padaria (dados para o cupom fiscal) ---
PADARIA_NOME="Padaria & Confeitaria Exemplo"
PADARIA_CNPJ="00.000.000/0001-00"
PADARIA_ENDERECO="Rua das Flores, 123 - Centro"
PADARIA_CIDADE="São Paulo - SP"
PADARIA_TELEFONE="(11) 99999-9999"
PADARIA_MENSAGEM_RODAPE="Obrigado pela preferência! Volte sempre."

# --- Impressora Térmica ---
PRINTER_TYPE=usb               # usb | network | file
PRINTER_VENDOR_ID=0x0416       # Knup / genérico
PRINTER_PRODUCT_ID=0x5011
PRINTER_NETWORK_IP=192.168.1.100
PRINTER_NETWORK_PORT=9100
PRINTER_PAPER_WIDTH=80         # 80 ou 58 (mm)

# --- PIX (Gerencianet/EFI Bank) ---
PIX_ENABLED=false
PIX_CLIENT_ID=seu_client_id_aqui
PIX_CLIENT_SECRET=seu_client_secret_aqui
PIX_CERTIFICATE_PATH=./certs/certificado.p12
PIX_CERTIFICATE_PASSWORD=senha_certificado
PIX_PIX_KEY=sua@chave.pix
PIX_SANDBOX=true               # true = ambiente de homologação
PIX_WEBHOOK_URL=https://seudominio.com/api/pix/webhook

# --- Upload de imagens ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
