# =============================================================================
# TEMPLATE de cliente (cópia isolada).  Copie para deploy/clients/<slug>.env,
# preencha os valores e rode:  deploy/new-client.sh <slug> <dominio>
#
# Gere os segredos com:
#   python3 -c "import secrets;print(secrets.token_hex(32))"   # JWT
#   python3 -c "import secrets;print(secrets.token_urlsafe(24))" # DB
#   python3 -c "import secrets;print(secrets.token_urlsafe(9))"  # admin
# =============================================================================

# --- Identidade da stack ---
COMPOSE_PROJECT_NAME=erp-padaria-<slug>
TENANT_SLUG=<slug>
BACKEND_PORT=<porta_livre_127.0.0.1>     # ex.: 8022
BACKEND_ENV_FILE=deploy/clients/<slug>.env

# --- Aplicação ---
APP_NAME=ERP Padaria
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# --- Banco ---
DB_HOST=<slug>-db
DB_PORT=5432
DB_NAME=erp_<slug>
DB_USER=<slug>_user
DB_PASSWORD=<gerar>

# --- JWT ---
JWT_SECRET_KEY=<gerar>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=https://<dominio>

# --- Branding / cupom ---
PADARIA_NOME=Nome da Padaria
PADARIA_CNPJ=00.000.000/0001-00
PADARIA_ENDERECO=
PADARIA_CIDADE=
PADARIA_TELEFONE=
PADARIA_MENSAGEM_RODAPE=Obrigado pela preferencia!

# --- Impressora ---
PRINTER_TYPE=file
PRINTER_PAPER_WIDTH=80

# --- PIX ---
PIX_ENABLED=false

# --- Upload ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# --- Admin inicial ---
ADMIN_EMAIL=admin@<dominio>
ADMIN_PASSWORD=<gerar>
ADMIN_NOME=Administrador
